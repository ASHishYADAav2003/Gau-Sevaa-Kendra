generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Animal {
  id             String   @id @default(uuid())
  name           String
  image          String
  age            String
  gender         String
  status         String
  rescueDate     DateTime
  story          String
  location       String
  monthlyExpense Float
  sponsored      Boolean  @default(false)
  healthStatus   String
  category       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Donation {
  id             String   @id @default(uuid())
  donorName      String
  email          String
  phone          String
  panCard        String?
  amount         Float
  paymentMethod  String
  isRecurring    Boolean  @default(false)
  paymentStatus  String   @default("Pending")
  date           DateTime @default(now())
}

model Volunteer {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String
  areaOfInterest String
  availability   String
  status         String   @default("Pending")
  createdAt      DateTime @default(now())
}

model Contact {
  id             String   @id @default(uuid())
  name           String
  email          String
  subject        String
  message        String
  createdAt      DateTime @default(now())
}
